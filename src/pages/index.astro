---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import heroImg from '../assets/taku-g-hero.png';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<img src={heroImg.src} alt="たくG" class="hero-img" />
				<div class="hero-text">
					<h1>たくG　ただの１日</h1>
					<p class="tagline">入院を機に気づいた、日常のありがたさ。<br />シブいおじいちゃんたくGの、笑えてちょっと泣ける体験談。</p>
					<div class="hero-links">
						<a href="/blog" class="btn-primary">ブログを読む</a>
						<a href="/about" class="btn-secondary">たくGとは？</a>
					</div>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero-img {
		width: 260px;
		height: auto;
		margin-bottom: 1em;
		border-radius: 50%;
		box-shadow: 0 8px 32px rgba(74,158,221,0.25);
	}
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		padding: 3em 1em;
	}
	.hero h1 {
		font-size: 2.8em;
		color: #1a6fa8;
		margin-bottom: 0.5em;
	}
	.tagline {
		font-size: 1.1em;
		color: #555;
		line-height: 1.8;
		margin-bottom: 2em;
	}
	.hero-links {
		display: flex;
		gap: 1em;
		justify-content: center;
		flex-wrap: wrap;
	}
	.btn-primary {
		background: #4a9edd;
		color: white;
		padding: 0.7em 1.8em;
		border-radius: 2em;
		text-decoration: none;
		font-weight: bold;
		transition: background 0.2s;
	}
	.btn-primary:hover {
		background: #1a6fa8;
		color: white;
	}
	.btn-secondary {
		background: white;
		color: #4a9edd;
		padding: 0.7em 1.8em;
		border-radius: 2em;
		text-decoration: none;
		font-weight: bold;
		border: 2px solid #4a9edd;
		transition: all 0.2s;
	}
	.btn-secondary:hover {
		background: #4a9edd;
		color: white;
	}
</style>
